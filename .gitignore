memory/**/secrets.json
memory/**/credentials.json

# Notion sync caches
.notion-cache/

# n8n workflows credentials (export workflows WITHOUT credentials)
n8n-workflows/**/*-with-credentials.json

# OS-specific
.Trashes
.AppleDouble
.LSOverride

# Credentials and secrets (NEVER commit)
.claude/
n8n-workflows/x-agent/N8N_CREDENTIALS_SETUP.md
**/AGS_Credentials_Internal.md
