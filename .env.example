# AGS Agents - Environment Variables Template
# Copy this file to .env and fill in values. NEVER commit .env to git.

# === Anthropic ===
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL_DEFAULT=claude-sonnet-4-6
ANTHROPIC_MODEL_FAST=claude-haiku-4-5-20251001

# === Twitter / X API v2 ===
X_API_KEY=
X_API_SECRET=
X_BEARER_TOKEN=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

# === Telegram ===
TELEGRAM_BOT_TOKEN_X_AGENT=
TELEGRAM_BOT_TOKEN_LINKEDIN_AGENT=
TELEGRAM_BOT_TOKEN_MANAGER=
TELEGRAM_CHAT_ID_TOMASZ=

# === LinkedIn (via Closely) ===
CLOSELY_API_KEY=
CLOSELY_USER_ID=

# === Notion ===
NOTION_API_KEY=secret_...
NOTION_BUILD_LOG_DB_ID=
NOTION_TRACKER_PAGE_ID=

# === n8n ===
N8N_BASE_URL=https://n8n.your-domain.com
N8N_API_KEY=

# === GHL ===
GHL_API_KEY=
GHL_LOCATION_ID=

# === Optional: ElevenLabs (custom voice) ===
ELEVENLABS_API_KEY=
